{
  "expo": {
    "name": "机器人控制中心",
    "slug": "ylhb-robot-mobile",
    "scheme": "ylhbrobot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "android": {
      "package": "com.ylhb.robotmobile",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
